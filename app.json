{
  "expo": {
    "name": "夜空のコンパニオン",
    "slug": "yozora-companion",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "yozora",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#141029",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.github.pppzet.yozoracompanion"
    },
    "android": {
      "package": "io.github.pppzet.yozoracompanion",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#141029"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "blockedPermissions": ["android.permission.RECORD_AUDIO"]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "expo-audio",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#141029",
          "image": "./assets/splash-icon.png",
          "imageWidth": 220
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "現在地の天気を表示するために位置情報を使います。"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#a78bfa"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-asset"
    ]
  }
}
